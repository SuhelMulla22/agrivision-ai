# AgriVision AI — Environment Configuration
# ===========================================

# Application
APP_NAME="AgriVision AI"
DEBUG=false
ENVIRONMENT=development

# Server
HOST=0.0.0.0
PORT=8000

# CORS (JSON array of origins)
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# ML Model
MODEL_DIR=ml/models
MODEL_NAME=crop_disease_model.h5
MODEL_VERSION=1.0.0
IMAGE_SIZE=224
CONFIDENCE_THRESHOLD=0.40
MAX_FILE_SIZE_MB=10

# Firebase (optional — leave empty for dev mode without Firebase)
FIREBASE_PROJECT_ID=
FIREBASE_CREDENTIALS_PATH=

# Security
SECRET_KEY=change-this-to-a-random-secret-key
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=10080

# Rate Limiting
RATE_LIMIT_PER_MINUTE=30

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
